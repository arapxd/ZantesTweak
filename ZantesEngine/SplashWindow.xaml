<Window x:Class="ZantesEngine.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="860"
        Height="520"
        MinWidth="820"
        MinHeight="500"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="appicon.ico"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="False">

    <Border CornerRadius="24"
            BorderBrush="#3D3152"
            BorderThickness="1"
            ClipToBounds="True">
        <Grid x:Name="Root" Background="#05050A">
            <Grid.Resources>
                <Style x:Key="BootPurpleBar" TargetType="ProgressBar">
                    <Setter Property="Height" Value="4"/>
                    <Setter Property="Background" Value="#1A1522"/>
                    <Setter Property="Foreground" Value="#BC9BFF"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ProgressBar">
                                <Grid>
                                    <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                                    <Border x:Name="PART_Indicator"
                                            Background="{TemplateBinding Foreground}"
                                            HorizontalAlignment="Left"
                                            CornerRadius="3"/>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Grid.Resources>

            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#04050A" Offset="0"/>
                        <GradientStop Color="#090A12" Offset="0.58"/>
                        <GradientStop Color="#11131B" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Rectangle Opacity="0.18"
                       IsHitTestVisible="False">
                <Rectangle.Fill>
                    <ImageBrush ImageSource="banner.png"
                                Stretch="UniformToFill"
                                AlignmentX="Center"
                                AlignmentY="Center"/>
                </Rectangle.Fill>
            </Rectangle>

            <Rectangle IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#D804050A" Offset="0"/>
                        <GradientStop Color="#A605050A" Offset="0.36"/>
                        <GradientStop Color="#EE05050A" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Ellipse Width="420"
                     Height="420"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Top"
                     Margin="0,-180,-140,0"
                     Opacity="0.16"
                     IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#A96FCAFF" Offset="0"/>
                        <GradientStop Color="#003B4F79" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Ellipse Width="360"
                     Height="360"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Bottom"
                     Margin="-120,0,0,-180"
                     Opacity="0.12"
                     IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#8A7B5BF0" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Canvas x:Name="ParticleCanvas"
                    IsHitTestVisible="False"
                    Visibility="Collapsed"/>

            <Grid Margin="34">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border x:Name="ContentPanel"
                        Grid.Row="0"
                        CornerRadius="28"
                        Background="#86101016"
                        BorderBrush="#433554"
                        BorderThickness="1"
                        Padding="28"
                        Opacity="0">
                    <Border.RenderTransform>
                        <TranslateTransform Y="24"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock x:Name="TxtSplashLayerLabel"
                                           Text="SYSTEM LAYER"
                                           Foreground="#B9AAD7"
                                           FontSize="10"
                                           FontWeight="Bold"/>
                                <Border x:Name="FirstBootBadge"
                                        Background="#231A32"
                                        BorderBrush="#715A96"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="10,4"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="TxtSplashFirstBootLabel"
                                               Text="FIRST BOOT EXPERIENCE"
                                               Foreground="#EFE7FC"
                                               FontSize="9"
                                               FontWeight="Bold"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        HorizontalAlignment="Right">
                                <TextBlock x:Name="TxtSplashDeployLabel"
                                           Text="DEPLOYMENT CORE"
                                           Foreground="#8D86A0"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           TextAlignment="Right"/>
                                <TextBlock x:Name="BootPercent"
                                           Text="5%"
                                           Margin="0,8,0,0"
                                           Foreground="#F4F0FB"
                                           FontFamily="Bahnschrift"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           TextAlignment="Right"/>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1"
                              Margin="0,22,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border x:Name="HeroFrame"
                                    Grid.Row="0"
                                    HorizontalAlignment="Center"
                                    CornerRadius="22"
                                    BorderBrush="#4B3C62"
                                    BorderThickness="1"
                                    Background="#120F18"
                                    Padding="14"
                                    Opacity="0">
                                <Border.RenderTransform>
                                    <TranslateTransform Y="18"/>
                                </Border.RenderTransform>
                                <Border CornerRadius="16"
                                        ClipToBounds="True">
                                    <Grid>
                                        <Image Source="banner.png"
                                               Width="470"
                                               Stretch="Uniform"/>
                                        <Rectangle>
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#2204050A" Offset="0"/>
                                                    <GradientStop Color="#A005050A" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                    </Grid>
                                </Border>
                            </Border>

                            <TextBlock Grid.Row="1"
                                       Text="ZANTES TWEAK"
                                       Margin="0,20,0,0"
                                       Foreground="#F8F4FC"
                                       FontFamily="Bahnschrift"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>

                            <TextBlock x:Name="TxtSplashSubtitle"
                                       Grid.Row="2"
                                       Text="Launch Core"
                                       Margin="0,2,0,0"
                                       Foreground="#B999F0"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>

                            <TextBlock x:Name="TxtSplashDesc"
                                       Grid.Row="3"
                                       Width="560"
                                       Margin="0,14,0,0"
                                       Text="Startup layer syncs modules, verifies session state and prepares the interface shell before the dashboard opens."
                                       Foreground="#BEB5CD"
                                       FontSize="11"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center"/>

                            <StackPanel Grid.Row="4"
                                        VerticalAlignment="Bottom"
                                        Margin="0,26,0,0">
                                <TextBlock x:Name="BootStatus"
                                           Text="Preparing startup sequence..."
                                           Foreground="#F4F0FB"
                                           FontFamily="Bahnschrift"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           TextAlignment="Center"/>
                                <TextBlock x:Name="BootHint"
                                           Text="Validating environment"
                                           Margin="0,8,0,0"
                                           Foreground="#AAA1BA"
                                           FontSize="12"
                                           TextAlignment="Center"/>
                                <TextBlock x:Name="BootModeHint"
                                           Text="Standard startup mode"
                                           Margin="0,4,0,0"
                                           Foreground="#7D768D"
                                           FontSize="10"
                                           TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="2"
                              Margin="0,22,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <ProgressBar x:Name="BootProgress"
                                             Style="{StaticResource BootPurpleBar}"
                                             Value="5"
                                             Maximum="100"/>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,10,0,0">
                                    <Ellipse x:Name="Dot"
                                             Width="7"
                                             Height="7"
                                             Fill="#B695FF"
                                             VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtSplashLoadingModules"
                                               Text="  Loading dashboard modules"
                                               Foreground="#BFB5CF"
                                               FontSize="10"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Bottom">
                                <TextBlock x:Name="TxtSplashShellLabel"
                                           Text="SHELL"
                                           Foreground="#7F7793"
                                           FontSize="10"
                                           FontWeight="Bold"/>
                                <TextBlock x:Name="TxtSplashShellValue"
                                           Text="Arming"
                                           Margin="8,0,0,0"
                                           Foreground="#EDE7FA"
                                           FontSize="10"
                                           FontWeight="Bold"/>
                                <TextBlock Text="  |  "
                                           Foreground="#6A6376"
                                           FontSize="10"/>
                                <TextBlock x:Name="TxtSplashProfileLabel"
                                           Text="PROFILE"
                                           Foreground="#7F7793"
                                           FontSize="10"
                                           FontWeight="Bold"/>
                                <TextBlock x:Name="TxtSplashProfileValue"
                                           Text="Syncing"
                                           Margin="8,0,0,0"
                                           Foreground="#EDE7FA"
                                           FontSize="10"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock x:Name="TxtSplashBrand"
                           Grid.Row="1"
                           Text="MADE BY ARAP"
                           Margin="0,18,0,0"
                           Foreground="#8F86A4"
                           FontSize="10"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
            </Grid>

            <Rectangle x:Name="BottomLine"
                       Height="1"
                       VerticalAlignment="Bottom"
                       Opacity="0">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#716090" Offset="0.34"/>
                        <GradientStop Color="#BC9BFF" Offset="0.5"/>
                        <GradientStop Color="#716090" Offset="0.66"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>
    </Border>
</Window>
