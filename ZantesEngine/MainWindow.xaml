                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="TxtSettingsVersionLabel"
                                                   Text="CURRENT VERSION"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontSize="10"
                                                   FontWeight="Bold"/>
                                        <TextBlock x:Name="TxtSettingsVersionValue"
                                                   Text="2.0.3"
                                                   Margin="0,8,0,0"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontSize="18"
                                                   FontWeight="Bold"/>
                                        <TextBlock x:Name="TxtSettingsUpdateStatus"
                                                   Text="Update channel is not configured yet."
                                                   Margin="0,8,0,0"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox x:Name="AutoCheckUpdatesToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource Toggle}"
                                              Click="AutoCheckUpdatesToggle_Click"
                                              VerticalAlignment="Top"/>
                                </Grid>

                                <TextBlock Grid.Row="2"
                                           x:Name="TxtSettingsAutoCheckLabel"
                                           Text="AUTO-CHECK ON LAUNCH"
                                           Margin="0,10,0,0"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="10"
                                           FontWeight="Bold"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="5"
                                Margin="0,16,0,0"
                                CornerRadius="18"
                                Background="#14141E"
                                BorderBrush="#382E49"
                                BorderThickness="1"
                                Padding="14">
                            <TextBlock x:Name="TxtSettingsCloseHint" Text="Click outside this panel to close settings."
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="10"/>
                        </Border>
                    </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
