<Window x:Class="ZantesEngine.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Zantes Tweak"
        Width="1360"
        Height="840"
        MinWidth="1120"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="False"
        FontFamily="Segoe UI"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        MouseMove="Window_MouseMove"
        MouseLeave="Window_MouseLeave">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="24"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="RailNavBtn" TargetType="RadioButton" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Height" Value="62"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="ShellCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Background" Value="#C11101A"/>
            <Setter Property="BorderBrush" Value="#3E3052"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="MutedChip" TargetType="Border">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Background" Value="#151520"/>
            <Setter Property="BorderBrush" Value="#382B4B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="DockNavProxy" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="18,10,18,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="Transparent"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel HorizontalAlignment="Center">
                                <ContentPresenter HorizontalAlignment="Center"/>
                                <Ellipse x:Name="SelectionDot"
                                         Width="5"
                                         Height="5"
                                         Margin="0,8,0,0"
                                         Fill="{StaticResource AccentPrimary}"
                                         Opacity="0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter TargetName="SelectionDot" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Border CornerRadius="28"
                Margin="0"
                Background="{StaticResource WindowBackgroundGradient}"
                ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="42" ShadowDepth="0" Opacity="0.34" Color="#020207"/>
            </Border.Effect>
        </Border>

        <Canvas x:Name="AmbientCanvas" Margin="0" IsHitTestVisible="False"/>

        <Grid Margin="0">
            <Rectangle IsHitTestVisible="False"
                       Opacity="0.68">
                <Rectangle.Fill>
                    <ImageBrush ImageSource="pack://application:,,,/banner.png"
                                Stretch="UniformToFill"
                                AlignmentX="Center"
                                AlignmentY="Center"/>
                </Rectangle.Fill>
            </Rectangle>

            <Rectangle IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#A8020203" Offset="0"/>
                        <GradientStop Color="#92050508" Offset="0.34"/>
                        <GradientStop Color="#8F090711" Offset="0.7"/>
                        <GradientStop Color="#AE030305" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Ellipse Width="420"
                     Height="420"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Top"
                     Margin="0,-170,-130,0"
                     IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#2C5A33A0" Offset="0"/>
                        <GradientStop Color="#001F1438" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Ellipse Width="300"
                     Height="300"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Bottom"
                     Margin="-120,0,0,-120"
                     IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#25442882" Offset="0"/>
                        <GradientStop Color="#00170D2E" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

                    <Border CornerRadius="28"
                            Background="#B10C0B14"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="78"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Margin="14,14,14,0"
                            CornerRadius="18"
                            Background="#C7141320"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Grid Margin="20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="46"
                                        Height="46"
                                        CornerRadius="16"
                                        ClipToBounds="True"
                                        BorderBrush="#5F4685"
                                        BorderThickness="1">
                                    <Image Source="pack://application:,,,/unnamed.jpg"
                                           Stretch="UniformToFill"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtAppName"
                                               Text="ZANTES TWEAK"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontFamily="Bahnschrift"
                                               FontSize="24"
                                               FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtAppControl"
                                               Text="TACTICAL CONSOLE"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="10"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Style="{StaticResource MutedChip}"
                                    Margin="20,12,14,12"
                                    VerticalAlignment="Stretch"
                                    Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="TxtHeaderHint"
                                                   Text="ADAPTIVE PERFORMANCE ENGINE"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="9"
                                                   FontWeight="Bold"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Ellipse Width="7" Height="7" Fill="{StaticResource AccentPrimary}" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtStatusStable"
                                                       Text="SYSTEM STABLE"
                                                       Margin="8,0,14,0"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                            <Ellipse Width="7" Height="7" Fill="#A884EE" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtStatusDiscord"
                                                       Text="DISCORD READY"
                                                       Margin="8,0,14,0"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                            <Ellipse Width="7" Height="7" Fill="#D8CBF4" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtStatusAuthorized"
                                                       Text="AUTHORIZED BY ZANTES"
                                                       Margin="8,0,0,0"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="CPU"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontSize="9"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock x:Name="HeaderCpu"
                                                   Text="0.0%"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontFamily="Bahnschrift"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Right"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                        <TextBlock Text="RAM"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontSize="9"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock x:Name="HeaderRam"
                                                   Text="0.0%"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontFamily="Bahnschrift"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtBrandCredit"
                                           Text="MADE BY ARAP"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="10"
                                           HorizontalAlignment="Right"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Button Style="{StaticResource WinBtn}" Click="BtnMin_Click">
                                    <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                                </Button>
                                <Button x:Name="BtnMax" Style="{StaticResource WinBtn}" Click="BtnMax_Click" Margin="8,0,0,0" Visibility="Collapsed">
                                    <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                                </Button>
                                <Button Style="{StaticResource CloseBtn}" Click="BtnClose_Click" Margin="8,0,0,0">
                                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="14,14,14,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0"/>
                            <ColumnDefinition Width="0"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0"
                                CornerRadius="26"
                                Background="#C0101119"
                                BorderBrush="#433259"
                                BorderThickness="1"
                                Padding="14"
                                Visibility="Collapsed">
                            <Grid x:Name="SidebarPanel">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        CornerRadius="22"
                                        Background="#171421"
                                        BorderBrush="#4A3A62"
                                        BorderThickness="1"
                                        ClipToBounds="True">
                                    <Grid>
                                        <Rectangle x:Name="SessionBackgroundVisual" Opacity="0.24">
                                            <Rectangle.Fill>
                                                <ImageBrush ImageSource="pack://application:,,,/banner.png"
                                                            Stretch="UniformToFill"
                                                            AlignmentX="Center"
                                                            AlignmentY="Center"/>
                                            </Rectangle.Fill>
                                        </Rectangle>

                                        <Rectangle Fill="#B60E0E18"/>

                                        <Rectangle VerticalAlignment="Bottom" Height="104">
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#0014141D" Offset="0"/>
                                                    <GradientStop Color="#D4141320" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>

                                        <TextBlock x:Name="AvatarFallbackText"
                                                   Text="?"
                                                   Margin="0,0,18,16"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Bottom"
                                                   Foreground="#4CA56CFF"
                                                   FontFamily="Bahnschrift"
                                                   FontSize="64"
                                                   FontWeight="Bold"
                                                   Opacity="0.24"/>

                                        <Grid Margin="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="68"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Grid Width="68" Height="68" VerticalAlignment="Center">
                                                <Ellipse Fill="#A8121320"
                                                         Stroke="#6A4F93"
                                                         StrokeThickness="1"/>
                                                <Ellipse x:Name="DiscordAvatar"
                                                         Margin="4"
                                                         Fill="#252131"
                                                         Stroke="#A584DB"
                                                         StrokeThickness="1"/>
                                            </Grid>

                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock x:Name="TxtSessionLabel"
                                                           Text="SESSION"
                                                           Foreground="#C9B8E6"
                                                           FontSize="9"
                                                           FontWeight="Bold"/>
                                                <TextBlock x:Name="AuthStatusText"
                                                           Text="LOCKED"
                                                           Margin="0,6,0,0"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontFamily="Bahnschrift"
                                                           FontSize="24"
                                                           FontWeight="Bold"/>
                                                <TextBlock x:Name="TxtDiscordUserLabel"
                                                           Text="DISCORD USER"
                                                           Margin="0,10,0,0"
                                                           Foreground="#B4A6CC"
                                                           FontSize="9"
                                                           FontWeight="Bold"/>
                                                <TextBlock x:Name="TxtDiscordUserName"
                                                           Text="Not linked"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="1"
                                        Margin="0,14,0,0"
                                        Height="0"
                                        Visibility="Collapsed"/>

                                <StackPanel Grid.Row="2" Margin="0,18,0,0">
                                    <RadioButton x:Name="NavDashboard"
                                                 Tag="dashboard"
                                                 Style="{StaticResource RailNavBtn}"
                                                 Checked="Nav_Checked">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE80F;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       Foreground="{StaticResource AccentPrimary}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock x:Name="TxtNavDashboard"
                                                           Text="DASHBOARD"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                           FontWeight="Bold"
                                                           FontSize="12"/>
                                            </StackPanel>
                                        </Grid>
                                    </RadioButton>

                                    <RadioButton x:Name="NavQuickBoost"
                                                 Tag="quickboost"
                                                 Style="{StaticResource RailNavBtn}"
                                                 Visibility="Collapsed"
                                                 Margin="0,4,0,0"
                                                 Checked="Nav_Checked">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE945;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       Foreground="{StaticResource AccentPrimary}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock x:Name="TxtNavQuickBoost"
                                                           Text="QUICK BOOST"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                           FontWeight="Bold"
                                                           FontSize="12"/>
                                                <TextBlock Text="Fast, hardware-aware safe tuning"
                                                           Foreground="{StaticResource TextMuted}"
                                                           FontSize="10"/>
                                            </StackPanel>
                                        </Grid>
                                    </RadioButton>

                                    <RadioButton x:Name="NavOptimizer"
                                                 Tag="optimizer"
                                                 Style="{StaticResource RailNavBtn}"
                                                 Visibility="Collapsed"
                                                 Margin="0,4,0,0"
                                                 Checked="Nav_Checked">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE713;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       Foreground="{StaticResource AccentPrimary}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock x:Name="TxtNavOptimizer"
                                                           Text="BOOSTER LAB"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                           FontWeight="Bold"
                                                           FontSize="12"/>
                                                <TextBlock Text="Advanced tweaks and restore flow"
                                                           Foreground="{StaticResource TextMuted}"
                                                           FontSize="10"/>
                                            </StackPanel>
                                        </Grid>
                                    </RadioButton>

                                    <RadioButton x:Name="NavGameTuner"
                                                 Tag="tuner"
                                                 Style="{StaticResource RailNavBtn}"
                                                 Margin="0,4,0,0"
                                                 Checked="Nav_Checked">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE7FC;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       Foreground="{StaticResource AccentPrimary}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock x:Name="TxtNavTuner"
                                                           Text="GAME TUNER"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                           FontWeight="Bold"
                                                           FontSize="12"/>
                                            </StackPanel>
                                        </Grid>
                                    </RadioButton>

                                    <RadioButton x:Name="NavNetwork"
                                                 Tag="network"
                                                 Style="{StaticResource RailNavBtn}"
                                                 Margin="0,4,0,0"
                                                 Checked="Nav_Checked">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE968;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       Foreground="{StaticResource AccentPrimary}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock x:Name="TxtNavNetwork"
                                                           Text="NETWORK"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                           FontWeight="Bold"
                                                           FontSize="12"/>
                                            </StackPanel>
                                        </Grid>
                                    </RadioButton>

                                    <RadioButton x:Name="NavPerformance"
                                                 Tag="performance"
                                                 Style="{StaticResource RailNavBtn}"
                                                 Visibility="Collapsed"
                                                 Margin="0,4,0,0"
                                                 Checked="Nav_Checked">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE9D9;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       Foreground="{StaticResource AccentPrimary}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock x:Name="TxtNavPerformance"
                                                           Text="PERFORMANCE"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                           FontWeight="Bold"
                                                           FontSize="12"/>
                                                <TextBlock Text="Sensors and live device metrics"
                                                           Foreground="{StaticResource TextMuted}"
                                                           FontSize="10"/>
                                            </StackPanel>
                                        </Grid>
                                    </RadioButton>

                                    <RadioButton x:Name="NavBenchmark"
                                                 Tag="benchmark"
                                                 Style="{StaticResource RailNavBtn}"
                                                 Visibility="Collapsed"
                                                 Margin="0,4,0,0"
                                                 Checked="Nav_Checked">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE9D2;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       Foreground="{StaticResource AccentPrimary}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock x:Name="TxtNavBenchmark"
                                                           Text="BENCHMARK"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                           FontWeight="Bold"
                                                           FontSize="12"/>
                                                <TextBlock Text="Frame tests and score tracking"
                                                           Foreground="{StaticResource TextMuted}"
                                                           FontSize="10"/>
                                            </StackPanel>
                                        </Grid>
                                    </RadioButton>
                                </StackPanel>

                                <Border Grid.Row="3"
                                        Margin="0,14,0,0"
                                        CornerRadius="20"
                                        Background="#151623"
                                        BorderBrush="#47395F"
                                        BorderThickness="1"
                                        Padding="14">
                                    <Grid>
                                        <TextBlock x:Name="TxtSidebarTip"
                                                   Text="Run as Administrator for full tweak effects."
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Visibility="Collapsed"/>
                                        <Button HorizontalAlignment="Stretch"
                                                Style="{StaticResource GhostBtn}"
                                                Click="BtnOpenSettings_Click">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="&#xE713;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="11"
                                                           Margin="0,0,8,0"/>
                                                           <TextBlock x:Name="TxtSidebarSettingsButton"
                                                                   Text="SETTINGS"
                                                                   FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                CornerRadius="24"
                                Background="#7A09090D"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Padding="18,18,18,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Frame x:Name="MainFrame"
                                       Background="Transparent"
                                       NavigationUIVisibility="Hidden"/>

                                <Border Grid.Row="1"
                                        Margin="0,18,0,0"
                                        x:Name="DockBarPanel"
                                        CornerRadius="26"
                                        Background="#9807060D"
                                        BorderBrush="#352641"
                                        BorderThickness="0,1,0,0"
                                        Padding="16,10,16,8"
                                        IsEnabled="False">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <RadioButton x:Name="DockDashboardNav"
                                                     Grid.Column="1"
                                                     Style="{StaticResource DockNavProxy}"
                                                     Checked="DockDashboard_Checked">
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="&#xE80F;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                           FontSize="17"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock x:Name="TxtDockDashboard"
                                                           Text="ONE TAP"
                                                           Margin="0,7,0,0"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                           FontWeight="Bold"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </RadioButton>

                                        <RadioButton x:Name="DockTunerNav"
                                                     Grid.Column="2"
                                                     Margin="8,0,0,0"
                                                     Style="{StaticResource DockNavProxy}"
                                                     Checked="DockTuner_Checked">
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="&#xE7FC;"
                                                           FontFamily="Segoe MDL2 Assets"
