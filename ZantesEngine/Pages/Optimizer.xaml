<Page x:Class="ZantesEngine.Pages.OptimizerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False">
    <Grid Margin="22,18,22,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="MODULE 01" Foreground="{StaticResource TextSecondary}" FontSize="9" FontWeight="Bold"/>
                <TextBlock Text="BOOSTER LAB" Foreground="{StaticResource TextPrimary}" FontFamily="Bahnschrift" FontSize="31" FontWeight="Bold"/>
                <TextBlock Text="Advanced tweak profiles for Zantes Tweak" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,3,0,0"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="RECOMMENDED"
                    Click="Recommended_Click"
                    Margin="0,0,10,0"
                    Style="{StaticResource GhostBtn}"/>

            <Button Grid.Column="2"
                    Content="BACK"
                    Click="GoBack_Click"
                    Style="{StaticResource GhostBtn}"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="368"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#0B0C14"
                    BorderBrush="#352C47"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="SYSTEM CORE" Foreground="{StaticResource TextSecondary}" FontSize="9" FontWeight="Bold"/>

                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="High Performance Power Plan" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Activates Windows high-performance power scheme." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel>
                                <CheckBox x:Name="CbPowerHighPerformance" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="Disable Hibernation" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Frees disk space and disables hibernate state." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel>
                                <CheckBox x:Name="CbDisableHibernate" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="Disable Startup Delay" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Reduces startup app launch waiting delay." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel>
                                <CheckBox x:Name="CbDisableStartupDelay" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Disable Fast Startup" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/>
                                    <TextBlock Text="Disables hybrid boot startup mode." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/>
                                    <TextBlock Text="Caution: boot behavior may change on some systems." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="CbDisableFastStartup" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Disable Remote Assistance" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/>
                                    <TextBlock Text="Turns off Remote Assistance request support." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="CbDisableRemoteAssistance" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="CPU Minimum State 100%" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/>
                                    <TextBlock Text="Sets active plan minimum processor state to 100% on AC." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/>
                                    <TextBlock Text="Caution: can increase heat and power usage on laptops." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="CbCpuMinimumState100" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="CPU Maximum State 100%" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/>
                                    <TextBlock Text="Ensures active plan maximum processor state is 100% on AC." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="CbCpuMaximumState100" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="CPU Core Parking Off (AC)" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/>
                                    <TextBlock Text="Keeps logical processors unparked in active power plan." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/>
                                    <TextBlock Text="Caution: can increase temperature and idle power draw." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="CbCpuCoreParkingOff" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="VisualFX Performance" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Optimizes visual effects for performance mode." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel>
                                <CheckBox x:Name="CbVisualFxPerformance" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Disable Power Throttling" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/>
                                    <TextBlock Text="Prevents background CPU throttling behavior." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/>
                                    <TextBlock Text="Caution: may increase power usage." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="CbDisablePowerThrottling" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Disable NTFS Last Access" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/>
                                    <TextBlock Text="Reduces metadata writes for file access tracking." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/>
                                    <TextBlock Text="Caution: enterprise audit tools may expect this on." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="CbNtfsDisableLastAccess" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable NTFS 8dot3 Names" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Disables legacy 8.3 filename generation on NTFS." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/><TextBlock Text="Caution: very old installers/scripts may rely on 8.3 paths." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/></StackPanel><CheckBox x:Name="CbNtfsDisable8dot3" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Memory Compression" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Disables memory compression and page combining." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/><TextBlock Text="Caution: may reduce performance on low-RAM systems." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/></StackPanel><CheckBox x:Name="CbDisableMemoryCompression" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Start Recommendations" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Disables Start menu recommendation entries." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbDisableStartRecommendations" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Windows Spotlight" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Disables Spotlight and lock screen suggestion content." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbDisableWindowsSpotlight" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Advertising ID" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Turns off per-user advertising identifier tracking." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbDisableAdvertisingId" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Language List Access" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Prevents websites from using your language list for local content." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbDisableLanguageListAccess" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable App Launch Tracking" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Stops Windows from tracking app launches for Start and search." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbDisableAppLaunchTracking" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Tailored Experiences" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Turns off tailored suggestions that use diagnostic data." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbDisableTailoredExperiences" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Menu Show Delay" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Makes menus open instantly in desktop UI." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbDisableMenuShowDelay" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Window Animations" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Turns off minimize/restore animation for snappier desktop." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbDisableWindowAnimations" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Snap Windows" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Turns off Snap Assist and related multitasking helpers." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbDisableSnapWindows" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>

                        <TextBlock Text="GAMING LATENCY" Foreground="{StaticResource TextSecondary}" FontSize="9" FontWeight="Bold" Margin="0,16,0,0"/>

                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Mouse Acceleration" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Applies raw-like pointer behavior." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbDisableMouseAccel" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Enable Game Mode" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Turns on Windows Game Mode optimizations." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbEnableGameMode" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Game DVR" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Disables background capture and DVR overhead." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbDisableGameDvr" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Xbox Game Bar UI" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Disables startup panel and capture UI hooks." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbDisableXboxGamebar" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Fullscreen Optimizations" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Applies global FSO compatibility mode flags." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/><TextBlock Text="Caution: some older games may prefer default fullscreen behavior." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/></StackPanel><CheckBox x:Name="CbDisableFullscreenOptimizations" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Low-Latency Boot Profile" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Applies aggressive BCD timer and virtualization boot flags." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/><TextBlock Text="Caution: can affect Hyper-V, VBS, virtualization, and some anti-cheat setups." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/></StackPanel><CheckBox x:Name="CbLowLatencyBootProfile" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Hardware GPU Scheduling" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Enables modern GPU scheduler path." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbHwScheduling" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Foreground Priority Separation" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Boosts foreground app CPU responsiveness." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/><TextBlock Text="Caution: can reduce smoothness for heavy background tasks." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/></StackPanel><CheckBox x:Name="CbPrioritySeparation" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Sticky Keys Shortcut" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Prevents accidental Sticky Keys popup while gaming." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbDisableStickyKeys" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Network Throttling" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Removes multimedia network throttle limit." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/><TextBlock Text="Caution: can affect stream/download fairness on busy networks." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/></StackPanel><CheckBox x:Name="CbDisableNetworkThrottling" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="MMCSS System Responsiveness 10" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Adjusts system responsiveness for game foreground." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbMmcssSystemResponsiveness" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
