                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Print Spooler" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Stops print spooler service if printing is not needed." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/><TextBlock Text="Caution: printing and some PDF virtual printers may stop working." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/></StackPanel><CheckBox x:Name="CbDisablePrintSpooler" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Program Compatibility Assistant" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Disables background compatibility assistant service." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/><TextBlock Text="Caution: app compatibility prompts may no longer appear." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/></StackPanel><CheckBox x:Name="CbDisablePcaService" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Fax Service" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Stops legacy fax background service if unused." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/><TextBlock Text="Caution: built-in Windows Fax features will be unavailable." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/></StackPanel><CheckBox x:Name="CbDisableFaxService" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Transparency" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Reduces transparency effects in Windows UI." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbDisableTransparency" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Widgets" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Turns off widgets/taskbar feed components." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbDisableWidgets" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Copilot" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Disables Windows Copilot entry points." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbDisableCopilot" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Consumer Features" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Disables Windows consumer content and app suggestions." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbDisableConsumerFeatures" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Edge Background Mode" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Prevents Microsoft Edge from running in background." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbDisableEdgeBackgroundMode" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Phone Service" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Disables Phone Service background process." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/><TextBlock Text="Caution: Phone Link related integrations may stop working." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/></StackPanel><CheckBox x:Name="CbDisablePhoneService" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Remote Registry" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Disables Remote Registry service if not needed." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/><TextBlock Text="Caution: remote registry management tools will stop working." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/></StackPanel><CheckBox x:Name="CbDisableRemoteRegistry" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable SSDP &amp; UPnP Services" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Disables SSDP discovery and UPnP host services." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/><TextBlock Text="Caution: network discovery and auto port mapping may stop working." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/></StackPanel><CheckBox x:Name="CbDisableSsdpUpnpServices" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Automatic Maintenance" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Disables scheduled automatic maintenance tasks." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/><TextBlock Text="Caution: Windows maintenance and diagnostics may run less often." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/></StackPanel><CheckBox x:Name="CbDisableAutoMaintenance" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Windows Update Access" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Disables Windows Update policy access and auto update." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/><TextBlock Text="Caution: security and driver updates will stop until reverted." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/></StackPanel><CheckBox x:Name="CbDisableWindowsUpdateAccess" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Storage Sense" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Disables Storage Sense background cleanup automation." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbDisableStorageSense" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable OneDrive Startup" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Disables OneDrive auto-start entry for current user." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/><TextBlock Text="Caution: OneDrive will not auto-start with Windows." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/></StackPanel><CheckBox x:Name="CbDisableOneDriveStartup" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Disable Teams Auto Start" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Disables common Teams startup entries." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/><TextBlock Text="Caution: Teams will not auto-start after sign-in." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/></StackPanel><CheckBox x:Name="CbDisableTeamsAutoStart" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>

                        <TextBlock Text="MAINTENANCE" Foreground="{StaticResource TextSecondary}" FontSize="9" FontWeight="Bold" Margin="0,16,0,0"/>

                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Clean Temp Files" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Cleans temporary files in current user temp folder." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbCleanTemp" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="NVIDIA Shader Cache Cleanup" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Cleans NVIDIA DX and GL shader cache folders." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbNvidiaShaderCacheClean" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="DirectX Shader Cache Cleanup" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Cleans DirectX shader cache for fresh recompile." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbDirectXShaderCacheClean" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Clean Windows Update Cache" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Cleans Windows Update download cache." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/><TextBlock Text="Caution: can reset in-progress update downloads." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/></StackPanel><CheckBox x:Name="CbCleanWindowsUpdateCache" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Reset Windows Update Folder" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Rebuilds the SoftwareDistribution folder from scratch." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/><TextBlock Text="Caution: resets update history cache and in-progress update files." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/></StackPanel><CheckBox x:Name="CbResetWindowsUpdateFolder" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Clean Thumbnail Cache" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Cleans Windows Explorer thumbnail cache files." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbCleanThumbnailCache" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="FiveM Cache Cleanup" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Cleans temporary FiveM cache files for smoother streaming." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbFiveMCacheCleanup" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="FiveM Logs &amp; Crash Cleanup" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Cleans FiveM logs and crash reports." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel><CheckBox x:Name="CbFiveMLogsCleanup" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="FiveM NUI Storage Reset" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Resets FiveM NUI local storage for UI cache issues." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/><TextBlock Text="Caution: may sign you out from some server UI integrations." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/></StackPanel><CheckBox x:Name="CbFiveMNuiStorageReset" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                        <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Clear Prefetch" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold"/><TextBlock Text="Clears old prefetch entries." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/><TextBlock Text="Caution: first launch can be slower right after cleanup." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/></StackPanel><CheckBox x:Name="CbClearPrefetch" Grid.Column="1" Style="{StaticResource Toggle}" Checked="TweakSelectionChanged" Unchecked="TweakSelectionChanged" VerticalAlignment="Center"/></Grid></Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2"
                    Background="#0B0C14"
                    BorderBrush="#352C47"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="DEPLOYMENT CORE" Foreground="{StaticResource TextSecondary}" FontSize="9" FontWeight="Bold"/>
                        <TextBlock Text="APPLY TWEAKS" Foreground="{StaticResource TextPrimary}" FontSize="28" FontFamily="Bahnschrift" FontWeight="Bold" Margin="0,4,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="SELECTED" Foreground="{StaticResource TextSecondary}" FontSize="8" FontWeight="Bold"/>
                            <TextBlock x:Name="SelectedCountText" Text="0 tweak" Foreground="{StaticResource TextPrimary}" FontSize="34" FontFamily="Bahnschrift" FontWeight="Bold"/>
                            <TextBlock x:Name="AdminStatusText" Text="Admin check pending..." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                        <CheckBox x:Name="CbAutoRestorePoint"
                                  Style="{StaticResource SoftCheck}"
                                  Content="Create restore point before apply"
                                  Foreground="{StaticResource TextPrimary}"
                                  FontSize="11"
                                  IsChecked="True"/>
                        <TextBlock Text="Risk marked tweaks will ask extra confirmation." Foreground="#CDB7E8" FontSize="9" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,10,0,0">
                        <Button x:Name="BtnCreateRestorePoint"
                                Content="CREATE RESTORE POINT"
                                Click="CreateRestorePoint_Click"
                                Style="{StaticResource GhostBtn}"/>

                        <Button x:Name="BtnSelectAll"
                                Content="SELECT ALL"
                                Click="SelectAll_Click"
                                Style="{StaticResource GhostBtn}"
                                Margin="0,8,0,0"/>

                        <Button x:Name="BtnOneClickMaxFps"
                                Content="ONE-CLICK MAX FPS"
                                Click="OneClickMaxFps_Click"
                                Style="{StaticResource GhostBtn}"
                                Margin="0,8,0,0"/>

                        <Button x:Name="BtnApplyTweaks"
                                Content="APPLY SELECTED TWEAKS"
                                Click="ApplySelected_Click"
                                Style="{StaticResource PrimaryBtn}"
                                Margin="0,8,0,0"
                                Height="40"/>
                    </StackPanel>

                    <TextBox x:Name="OutputBox"
                             Grid.Row="4"
                             Style="{StaticResource ConsoleBox}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             Margin="0,12,0,0"/>

                    <Border x:Name="ActionToast"
                            Grid.RowSpan="5"
                            VerticalAlignment="Top"
                            Margin="0,0,0,0"
                            Background="#E3181220"
                            BorderBrush="#7A659C"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="ActionToastTitle"
                                       Text="TASK RUNNING"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontWeight="Bold"
                                       FontSize="11"/>
                            <TextBlock x:Name="ActionToastBody"
                                       Text="Applying tweaks..."
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="10"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>
                            <ProgressBar x:Name="ActionToastProgress"
                                         Style="{StaticResource PurpleBar}"
                                         Height="3"
                                         IsIndeterminate="True"
                                         Margin="0,9,0,0"
                                         Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
    </ScrollViewer>
</Page>

