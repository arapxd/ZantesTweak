<Page x:Class="ZantesEngine.Pages.Dashboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      FontFamily="Segoe UI">

    <Page.Resources>
        <Style x:Key="OrbButton" TargetType="Button">
            <Setter Property="Foreground" Value="#09070D"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="Orb"
                                    Background="{StaticResource PrimaryButtonGradient}"
                                    CornerRadius="999"/>
                            <Border x:Name="OrbStroke"
                                    Margin="8"
                                    CornerRadius="999"
                                    BorderBrush="#E4D6FF"
                                    BorderThickness="1"
                                    Opacity="0.25"/>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="OrbStroke" Property="Opacity" Value="0.5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Orb" Property="Opacity" Value="0.95"/>
                                <Setter TargetName="OrbStroke" Property="Opacity" Value="0.42"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Orb" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Orb" Property="Opacity" Value="0.45"/>
                                <Setter TargetName="OrbStroke" Property="Opacity" Value="0.12"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="18">
        <Grid>
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="620">
                <TextBlock x:Name="TxtHeroEyebrow"
                           Text="ONE TAP"
                           Foreground="{StaticResource AccentPrimary}"
                           FontSize="11"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtHeroTitle"
                           Text="FPS optimize, one command."
                           Margin="0,14,0,0"
                           Foreground="{StaticResource TextPrimary}"
                           FontFamily="Bahnschrift"
                           FontSize="46"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="TxtHeroBody"
                           Text="Creates a restore point first, then applies only evidence-backed FPS tweaks."
                           Margin="0,16,0,0"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="14"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>

                <Grid Margin="0,34,0,0"
                      HorizontalAlignment="Center">
                    <Ellipse Width="240"
                             Height="240"
                             Fill="#120F18"
                             Stroke="#4E3772"
                             StrokeThickness="1"/>
                    <Ellipse Width="208"
                             Height="208"
                             Fill="#0B0A10"
                             Stroke="#6E46A8"
                             StrokeThickness="1"/>
                    <Button x:Name="BtnHeroApply"
                            Width="176"
                            Height="176"
                            Style="{StaticResource OrbButton}"
                            Click="ApplySelectedNow_Click"
                            FontFamily="Bahnschrift"
                            FontSize="22"
                            FontWeight="Bold"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="TxtHeroButton"
                                   Text="RUN"/>
                        <Button.RenderTransform>
                            <ScaleTransform x:Name="BtnScale" ScaleX="1" ScaleY="1"/>
                        </Button.RenderTransform>
                        <Button.RenderTransformOrigin>0.5,0.5</Button.RenderTransformOrigin>
                    </Button>
                </Grid>

                <TextBlock x:Name="StatusText"
                           Margin="0,22,0,0"
                           Text="Ready to create restore point and apply full optimize."
                           Foreground="{StaticResource TextMuted}"
                           FontSize="13"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Grid x:Name="ProgressOverlay"
                  Visibility="Collapsed"
                  Opacity="0"
                  Background="#D9040406">
                <Border Width="420"
                        Padding="28"
                        CornerRadius="28"
                        Background="#110F16"
                        BorderBrush="#4A3470"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Width="92" Height="92" HorizontalAlignment="Center">
                            <Ellipse Stroke="#2B213B" StrokeThickness="8"/>
                            <Path Stroke="{StaticResource AccentPrimary}"
                                  StrokeThickness="8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M 46,10 A 36,36 0 0 1 82,46">
                                <Path.RenderTransform>
                                    <RotateTransform x:Name="SpinnerRotate" CenterX="46" CenterY="46"/>
                                </Path.RenderTransform>
                            </Path>
                        </Grid>

                        <TextBlock x:Name="OverlayTitle"
                                   Grid.Row="1"
                                   Margin="0,20,0,0"
                                   Text="Applying full optimize..."
                                   Foreground="{StaticResource TextPrimary}"
                                   FontFamily="Bahnschrift"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>

                        <TextBlock x:Name="OverlayStatus"
                                   Grid.Row="2"
                                   Margin="0,14,0,0"
                                   Text="Creating restore point, then applying all safe performance layers."
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="13"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
