<Page x:Class="ZantesEngine.Pages.NetworkPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      FontFamily="Segoe UI">

    <Grid Margin="22,18,22,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock x:Name="TxtModule" Text="MODULE 03" Foreground="{StaticResource TextSecondary}" FontSize="9" FontWeight="Bold"/>
                <TextBlock x:Name="TxtTitle" Text="NETWORK BOOSTER" Foreground="{StaticResource TextPrimary}" FontFamily="Bahnschrift" FontSize="31" FontWeight="Bold"/>
            </StackPanel>

            <Button Grid.Column="1" Content="BACK" Click="GoBack_Click" Style="{StaticResource GhostBtn}"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#0B0C14" BorderBrush="#352C47" BorderThickness="1" CornerRadius="12" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <UniformGrid Columns="3">
                        <Border Margin="0,0,8,0" Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="10">
                            <StackPanel>
                                <TextBlock x:Name="TxtPingLabel" Text="PING" Foreground="{StaticResource TextSecondary}" FontSize="8" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtPingValue" Text="-- ms" Foreground="{StaticResource TextPrimary}" FontSize="20" FontFamily="Bahnschrift" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,8,0" Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="10">
                            <StackPanel>
                                <TextBlock x:Name="TxtJitterLabel" Text="JITTER" Foreground="{StaticResource TextSecondary}" FontSize="8" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtJitterValue" Text="-- ms" Foreground="{StaticResource TextPrimary}" FontSize="20" FontFamily="Bahnschrift" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="10">
                            <StackPanel>
                                <TextBlock x:Name="TxtLossLabel" Text="PACKET LOSS" Foreground="{StaticResource TextSecondary}" FontSize="8" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtLossValue" Text="-- %" Foreground="{StaticResource TextPrimary}" FontSize="20" FontFamily="Bahnschrift" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock x:Name="TxtRouteLabel" Text="ROUTE STACK" Foreground="{StaticResource TextSecondary}" FontSize="9" FontWeight="Bold"/>

                            <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0">
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="TCP Auto-Tuning Normal" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="13"/><TextBlock Text="Uses balanced TCP scaling profile." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel>
                                    <CheckBox x:Name="CbTcpAutotune" Grid.Column="1" Style="{StaticResource Toggle}" VerticalAlignment="Center" IsChecked="True"/>
                                </Grid>
                            </Border>

                            <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0">
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="Enable Receive Side Scaling" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="13"/><TextBlock Text="Distributes packet handling across CPU cores." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel>
                                    <CheckBox x:Name="CbNetworkRss" Grid.Column="1" Style="{StaticResource Toggle}" VerticalAlignment="Center" IsChecked="True"/>
                                </Grid>
                            </Border>

                            <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0">
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="Disable TCP Heuristics" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="13"/><TextBlock Text="Keeps stable autotune profile under load." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/></StackPanel>
                                    <CheckBox x:Name="CbTcpHeuristics" Grid.Column="1" Style="{StaticResource Toggle}" VerticalAlignment="Center" IsChecked="True"/>
                                </Grid>
                            </Border>

                            <Border Background="#141522" BorderBrush="#604D78" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0">
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="Disable Network Throttling" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="13"/><TextBlock Text="Lowers multimedia packet throttle limits." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/><TextBlock Text="Caution: can increase burst traffic behavior." Foreground="#CDB7E8" FontSize="9" Margin="0,4,0,0"/></StackPanel>
                                    <CheckBox x:Name="CbDisableNetworkThrottle" Grid.Column="1" Style="{StaticResource Toggle}" VerticalAlignment="Center" IsChecked="True"/>
                                </Grid>
                            </Border>

                            <TextBlock x:Name="TxtSpikeGuardLabel" Text="NETWORK SPIKE GUARD" Foreground="{StaticResource TextSecondary}" FontSize="9" FontWeight="Bold" Margin="0,16,0,0"/>
                            <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,8,0,0">
                                <StackPanel>
                                    <CheckBox x:Name="CbSpikeGuard"
                                              Content="Enable auto safe profile on spike"
                                              Style="{StaticResource SoftCheck}"
                                              IsChecked="True"/>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="TxtSpikeThresholdLabel" Text="Spike Threshold" Foreground="{StaticResource TextSecondary}" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtSpikeThresholdValue" Grid.Column="1" Text="80 ms" Foreground="{StaticResource TextPrimary}" FontSize="10" FontWeight="Bold"/>
                                    </Grid>

                                    <Slider x:Name="SldSpikeThreshold"
                                            Minimum="40"
                                            Maximum="220"
                                            Value="80"
                                            Margin="0,6,0,0"
                                            ValueChanged="SldSpikeThreshold_ValueChanged"/>

                                    <CheckBox x:Name="CbCreateRestoreOnSpike"
                                              Content="Create restore point before auto apply"
                                              Style="{StaticResource SoftCheck}"
                                              IsChecked="True"
                                              Margin="0,10,0,0"/>

                                    <TextBlock x:Name="TxtSpikeState"
                                               Text="Spike guard armed."
                                               Foreground="#9FB1C7"
                                               FontSize="10"
                                               Margin="0,10,0,0"
                                               TextWrapping="Wrap"/>

                                    <Button x:Name="BtnApplyRouteProfile"
                                            Content="APPLY ROUTE PROFILE"
                                            Style="{StaticResource PrimaryBtn}"
                                            Height="36"
                                            Margin="0,12,0,0"
                                            Click="BtnApplyRouteProfile_Click"/>
                                </StackPanel>
                            </Border>

                            <TextBox x:Name="OutputBox"
                                     Style="{StaticResource ConsoleBox}"
                                     Margin="0,12,0,0"
                                     MinHeight="120"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     AcceptsReturn="True"
                                     IsReadOnly="True"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="#0B0C14" BorderBrush="#352C47" BorderThickness="1" CornerRadius="12" Padding="14">
                <StackPanel>
                    <TextBlock x:Name="TxtRouteProfileLabel" Text="ROUTE PROFILE" Foreground="{StaticResource TextSecondary}" FontSize="9" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtRouteProfileName" Text="Low Latency Guard" Foreground="{StaticResource TextPrimary}" FontFamily="Bahnschrift" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                    <ProgressBar x:Name="RouteScoreBar" Style="{StaticResource PurpleBar}" Value="68" Maximum="100" Margin="0,16,0,0"/>
                    <TextBlock x:Name="TxtRouteScore" Text="68% network readiness" Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,8,0,0"/>

                    <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock x:Name="TxtDriverPresetLabel" Text="AUTO DRIVER PRESET" Foreground="{StaticResource TextSecondary}" FontSize="9" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtDetectedVendor" Text="Detected GPU: Unknown" Foreground="{StaticResource TextPrimary}" FontSize="11" FontWeight="SemiBold" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <Button x:Name="BtnApplyDriverPreset"
                                    Content="APPLY DRIVER PRESET"
                                    Style="{StaticResource GhostBtn}"
                                    Margin="0,10,0,0"
                                    Height="34"
                                    Click="BtnApplyDriverPreset_Click"/>
                            <TextBlock x:Name="TxtDriverHint"
                                       Text="Applies vendor-aware safe FPS profile."
                                       Foreground="#9FB1C7"
                                       FontSize="10"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#141522" BorderBrush="#44385B" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock x:Name="TxtWizardLabel" Text="AUTO-TUNE WIZARD" Foreground="{StaticResource TextSecondary}" FontSize="9" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtWizardDesc" Text="Tests DNS latency and MTU, then builds a recommended profile." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,6,0,0" TextWrapping="Wrap"/>

                            <Button x:Name="BtnRunWizard"
                                    Content="RUN ANALYSIS"
                                    Style="{StaticResource GhostBtn}"
                                    Margin="0,10,0,0"
                                    Height="34"
                                    Click="BtnRunWizard_Click"/>

                            <Border Background="#132433" BorderBrush="#33516A" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,10,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="TxtWizardStatus" Text="Status: Idle" Foreground="{StaticResource TextPrimary}" FontSize="10" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TxtWizardBestDns" Text="Best DNS: -" Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,5,0,0"/>
                                    <TextBlock x:Name="TxtWizardMtu" Text="Recommended MTU payload: -" Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/>
                                    <TextBlock x:Name="TxtWizardProfile" Text="Profile: -" Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>

                            <CheckBox x:Name="CbApplyRecommendedDns"
                                      Content="Apply recommended DNS servers"
                                      Style="{StaticResource SoftCheck}"
                                      IsChecked="True"
                                      Margin="0,10,0,0"/>

                            <Button x:Name="BtnApplyWizard"
                                    Content="APPLY AUTO-TUNE"
                                    Style="{StaticResource PrimaryBtn}"
                                    Margin="0,10,0,0"
                                    Height="36"
                                    Click="BtnApplyWizard_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>

