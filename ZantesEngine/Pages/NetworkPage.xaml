<Page x:Class="ZantesEngine.Pages.NetworkPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
      Background="Transparent"
      FontFamily="Segoe UI">

    <Page.Resources>
        <Style x:Key="ToolTile" TargetType="primitives:ToggleButton">
            <Setter Property="Margin" Value="0,0,14,14"/>
            <Setter Property="Width" Value="220"/>
            <Setter Property="MinHeight" Value="116"/>
            <Setter Property="Background" Value="#8E101117"/>
            <Setter Property="BorderBrush" Value="#463456"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="primitives:ToggleButton">
                        <Border x:Name="TileBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="14">
                            <Grid>
                                <Border x:Name="StateBadge"
                                        Width="20"
                                        Height="20"
                                        CornerRadius="10"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Background="#181322"
                                        BorderBrush="#4E3C68"
                                        BorderThickness="1">
                                    <TextBlock Text="+"
                                               Foreground="{StaticResource AccentPrimary}"
                                               FontSize="18"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ContentPresenter Margin="0,0,26,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TileBorder" Property="Background" Value="#A7161320"/>
                                <Setter TargetName="TileBorder" Property="BorderBrush" Value="#8E6AE0"/>
                                <Setter TargetName="StateBadge" Property="Background" Value="#3A2250"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TileBorder" Property="BorderBrush" Value="#70549F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VendorCard" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg"
                                Width="156"
                                MinHeight="98"
                                CornerRadius="18"
                                Background="#8E101117"
                                BorderBrush="#463456"
                                BorderThickness="1"
                                Padding="14">
                            <StackPanel>
                                <TextBlock x:Name="VendorGlyph"
                                           Text="N"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                           FontFamily="Bahnschrift"
                                           FontSize="22"
                                           FontWeight="Bold"/>
                                <ContentPresenter Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="nvidia">
                                <Setter TargetName="VendorGlyph" Property="Text" Value="N"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="amd">
                                <Setter TargetName="VendorGlyph" Property="Text" Value="A"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="intel">
                                <Setter TargetName="VendorGlyph" Property="Text" Value="I"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#70549F"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#A7161320"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#8E6AE0"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="22">
        <ScrollViewer x:Name="MainScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Padding="18"
                        CornerRadius="24"
                        Background="#78101119"
                        BorderBrush="#3D2F4C"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,20,0">
                            <TextBlock x:Name="TxtEyebrow"
                                       Text="NET + TOOLS"
                                       Foreground="{StaticResource AccentPrimary}"
                                       FontSize="10"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="TxtTitle"
                                       Text="Latency-side tools, TCP cleanup, and driver presets."
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontFamily="Bahnschrift"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="TxtSubtitle"
                                       Text="Fast Startup intentionally stays out. Pick the cards you want, then apply the tool stack or a dedicated driver profile."
                                       Margin="0,10,0,0"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="TxtStackPreviewLabel"
                                       Text="STACK PREVIEW"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="10"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="TxtSelectedCount"
                                       Text="8 selected"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontFamily="Bahnschrift"
                                       FontSize="24"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="TxtPreviewHint"
                                       Text="Restore point first, then selected tweaks."
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                            <Border Margin="0,14,0,0"
                                    Padding="12"
                                    CornerRadius="16"
                                    Background="#6110151D"
                                    BorderBrush="#463456"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock x:Name="TxtDriverPreviewLabel"
                                               Text="DRIVER TARGET"
                                               Foreground="{StaticResource TextMuted}"
                                               FontSize="10"
                                               FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtDriverPreviewValue"
                                               Text="NVIDIA"
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontFamily="Bahnschrift"
                                               FontSize="22"
                                               FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtDriverPreviewHint"
                                               Text="Manual vendor preset is ready."
                                               Margin="0,4,0,0"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="10"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Margin="0,16,0,0"
                        CornerRadius="24"
                        Background="#7D0D0C13"
                        BorderBrush="#382A45"
                        BorderThickness="1"
                        Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TxtToolsSectionLabel"
                                       Text="NETWORK STACK"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="BtnApplyTools"
                                    Grid.Column="1"
                                    MinWidth="210"
                                    Height="44"
                                    Style="{StaticResource PrimaryBtn}"
                                    Click="ApplyTools_Click">
                                <TextBlock x:Name="TxtApplyToolsButton"
                                           Text="APPLY SELECTED TOOLS"
                                           FontWeight="Bold"/>
                            </Button>
                        </Grid>

                        <StackPanel Grid.Row="1"
                                    Margin="0,14,0,0">
                            <TextBlock x:Name="TxtFooterTitle"
                                       Text="Apply only what you actually want."
                                       Foreground="{StaticResource TextPrimary}"
                                       FontFamily="Bahnschrift"
                                       FontSize="20"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="StatusText"
                                       Text="Ready to create restore point and apply the selected tools."
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <WrapPanel Grid.Row="2"
                                   Margin="0,16,0,0">
                            <primitives:ToggleButton x:Name="ToolTcpOptimizer" Style="{StaticResource ToolTile}" Tag="tcp_autotune|network_rss|disable_network_throttling" IsChecked="True" Checked="ToolTile_Changed" Unchecked="ToolTile_Changed"><StackPanel><TextBlock x:Name="TxtCardTcpOptimizerTitle" Text="TCP OPTIMIZER" Foreground="{StaticResource TextPrimary}" FontFamily="Bahnschrift" FontSize="20" FontWeight="Bold"/><TextBlock x:Name="TxtCardTcpOptimizerDesc" Text="Applies low-latency TCP auto-tuning, RSS, and network throttling fixes." Margin="0,8,0,0" Foreground="{StaticResource TextSecondary}" FontSize="11" TextWrapping="Wrap"/></StackPanel></primitives:ToggleButton>
                            <primitives:ToggleButton x:Name="ToolFlushDns" Style="{StaticResource ToolTile}" Tag="dns_flush" IsChecked="True" Checked="ToolTile_Changed" Unchecked="ToolTile_Changed"><StackPanel><TextBlock x:Name="TxtCardFlushDnsTitle" Text="FLUSH DNS" Foreground="{StaticResource TextPrimary}" FontFamily="Bahnschrift" FontSize="20" FontWeight="Bold"/><TextBlock x:Name="TxtCardFlushDnsDesc" Text="Clears cached DNS entries instantly to remove stale route lookups." Margin="0,8,0,0" Foreground="{StaticResource TextSecondary}" FontSize="11" TextWrapping="Wrap"/></StackPanel></primitives:ToggleButton>
                            <primitives:ToggleButton x:Name="ToolWinsockReset" Style="{StaticResource ToolTile}" Tag="winsock_reset" Checked="ToolTile_Changed" Unchecked="ToolTile_Changed"><StackPanel><TextBlock x:Name="TxtCardWinsockTitle" Text="WINSOCK RESET" Foreground="{StaticResource TextPrimary}" FontFamily="Bahnschrift" FontSize="18" FontWeight="Bold"/><TextBlock x:Name="TxtCardWinsockDesc" Text="Resets the socket catalog when network hooks or filters get messy." Margin="0,8,0,0" Foreground="{StaticResource TextSecondary}" FontSize="11" TextWrapping="Wrap"/></StackPanel></primitives:ToggleButton>
                            <primitives:ToggleButton x:Name="ToolTcpHeuristics" Style="{StaticResource ToolTile}" Tag="tcp_heuristics_disabled" IsChecked="True" Checked="ToolTile_Changed" Unchecked="ToolTile_Changed"><StackPanel><TextBlock x:Name="TxtCardHeuristicsTitle" Text="TCP HEURISTICS" Foreground="{StaticResource TextPrimary}" FontFamily="Bahnschrift" FontSize="18" FontWeight="Bold"/><TextBlock x:Name="TxtCardHeuristicsDesc" Text="Stops Windows TCP heuristics from undoing your chosen network tuning." Margin="0,8,0,0" Foreground="{StaticResource TextSecondary}" FontSize="11" TextWrapping="Wrap"/></StackPanel></primitives:ToggleButton>
                            <primitives:ToggleButton x:Name="ToolTcpChimney" Style="{StaticResource ToolTile}" Tag="tcp_chimney_disabled" IsChecked="True" Checked="ToolTile_Changed" Unchecked="ToolTile_Changed"><StackPanel><TextBlock x:Name="TxtCardChimneyTitle" Text="TCP CHIMNEY" Foreground="{StaticResource TextPrimary}" FontFamily="Bahnschrift" FontSize="20" FontWeight="Bold"/><TextBlock x:Name="TxtCardChimneyDesc" Text="Disables legacy chimney offload that can cause inconsistent NIC behavior." Margin="0,8,0,0" Foreground="{StaticResource TextSecondary}" FontSize="11" TextWrapping="Wrap"/></StackPanel></primitives:ToggleButton>
                            <primitives:ToggleButton x:Name="ToolTcpTimestamps" Style="{StaticResource ToolTile}" Tag="tcp_timestamps_disabled" Checked="ToolTile_Changed" Unchecked="ToolTile_Changed"><StackPanel><TextBlock x:Name="TxtCardTimestampsTitle" Text="TCP TIMESTAMPS" Foreground="{StaticResource TextPrimary}" FontFamily="Bahnschrift" FontSize="18" FontWeight="Bold"/><TextBlock x:Name="TxtCardTimestampsDesc" Text="Disables timestamp overhead when you want a leaner latency path." Margin="0,8,0,0" Foreground="{StaticResource TextSecondary}" FontSize="11" TextWrapping="Wrap"/></StackPanel></primitives:ToggleButton>
                            <primitives:ToggleButton x:Name="ToolSuperfetch" Style="{StaticResource ToolTile}" Tag="disable_sysmain" IsChecked="True" Checked="ToolTile_Changed" Unchecked="ToolTile_Changed"><StackPanel><TextBlock x:Name="TxtCardSuperfetchTitle" Text="SUPERFETCH" Foreground="{StaticResource TextPrimary}" FontFamily="Bahnschrift" FontSize="20" FontWeight="Bold"/><TextBlock x:Name="TxtCardSuperfetchDesc" Text="Cuts SysMain background disk churn and old preload behavior." Margin="0,8,0,0" Foreground="{StaticResource TextSecondary}" FontSize="11" TextWrapping="Wrap"/></StackPanel></primitives:ToggleButton>
                            <primitives:ToggleButton x:Name="ToolDynamicTick" Style="{StaticResource ToolTile}" Tag="disable_dynamic_tick" IsChecked="True" Checked="ToolTile_Changed" Unchecked="ToolTile_Changed"><StackPanel><TextBlock x:Name="TxtCardDynamicTickTitle" Text="DYNAMIC TICK" Foreground="{StaticResource TextPrimary}" FontFamily="Bahnschrift" FontSize="20" FontWeight="Bold"/><TextBlock x:Name="TxtCardDynamicTickDesc" Text="Disables dynamic tick for steadier timer behavior during active sessions." Margin="0,8,0,0" Foreground="{StaticResource TextSecondary}" FontSize="11" TextWrapping="Wrap"/></StackPanel></primitives:ToggleButton>
                            <primitives:ToggleButton x:Name="ToolTaskOffloading" Style="{StaticResource ToolTile}" Tag="disable_task_offload" IsChecked="True" Checked="ToolTile_Changed" Unchecked="ToolTile_Changed"><StackPanel><TextBlock x:Name="TxtCardTaskOffloadTitle" Text="TASK OFFLOADING" Foreground="{StaticResource TextPrimary}" FontFamily="Bahnschrift" FontSize="18" FontWeight="Bold"/><TextBlock x:Name="TxtCardTaskOffloadDesc" Text="Turns off legacy TCP task offload routing that can add weird driver behavior." Margin="0,8,0,0" Foreground="{StaticResource TextSecondary}" FontSize="11" TextWrapping="Wrap"/></StackPanel></primitives:ToggleButton>
                            <primitives:ToggleButton x:Name="ToolDisableNdu" Style="{StaticResource ToolTile}" Tag="disable_ndu_service" IsChecked="True" Checked="ToolTile_Changed" Unchecked="ToolTile_Changed"><StackPanel><TextBlock x:Name="TxtCardNduTitle" Text="DISABLE NDU" Foreground="{StaticResource TextPrimary}" FontFamily="Bahnschrift" FontSize="20" FontWeight="Bold"/><TextBlock x:Name="TxtCardNduDesc" Text="Turns off Windows data usage monitoring service overhead." Margin="0,8,0,0" Foreground="{StaticResource TextSecondary}" FontSize="11" TextWrapping="Wrap"/></StackPanel></primitives:ToggleButton>
                            <primitives:ToggleButton x:Name="ToolDiagTrack" Style="{StaticResource ToolTile}" Tag="disable_diagtrack_service" IsChecked="True" Checked="ToolTile_Changed" Unchecked="ToolTile_Changed"><StackPanel><TextBlock x:Name="TxtCardDiagTitle" Text="DIAG TRACK" Foreground="{StaticResource TextPrimary}" FontFamily="Bahnschrift" FontSize="20" FontWeight="Bold"/><TextBlock x:Name="TxtCardDiagDesc" Text="Stops telemetry tracking services that keep reporting in the background." Margin="0,8,0,0" Foreground="{StaticResource TextSecondary}" FontSize="11" TextWrapping="Wrap"/></StackPanel></primitives:ToggleButton>
                        </WrapPanel>
                    </Grid>
                </Border>

                <Border Margin="0,16,0,0"
                        CornerRadius="24"
                        Background="#7D0D0C13"
                        BorderBrush="#382A45"
                        BorderThickness="1"
                        Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="TxtDriverSectionLabel"
                                       Text="DRIVER PRESET"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="10"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="TxtDriverTitle"
                                       Text="Pick the GPU family yourself."
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontFamily="Bahnschrift"
                                       FontSize="24"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="TxtDriverBody"
                                       Text="Each vendor gets a different preset. Choose NVIDIA, AMD, or Intel and apply only that stack."
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,14,0,0">
                                <RadioButton x:Name="VendorNvidia" Tag="nvidia" Style="{StaticResource VendorCard}" Checked="Vendor_Checked"><StackPanel><TextBlock x:Name="TxtVendorNvidiaTitle" Text="NVIDIA" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" FontWeight="Bold" FontSize="15"/><TextBlock x:Name="TxtVendorNvidiaDesc" Text="Game Mode, MPO, NVIDIA telemetry and shader cache side." Margin="0,6,0,0" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" FontSize="9" TextWrapping="Wrap"/></StackPanel></RadioButton>
                                <RadioButton x:Name="VendorAmd" Tag="amd" Style="{StaticResource VendorCard}" Checked="Vendor_Checked"><StackPanel><TextBlock x:Name="TxtVendorAmdTitle" Text="AMD" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" FontWeight="Bold" FontSize="15"/><TextBlock x:Name="TxtVendorAmdDesc" Text="Balanced MPO-safe preset for Radeon systems." Margin="0,6,0,0" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" FontSize="9" TextWrapping="Wrap"/></StackPanel></RadioButton>
                                <RadioButton x:Name="VendorIntel" Tag="intel" Style="{StaticResource VendorCard}" Checked="Vendor_Checked"><StackPanel><TextBlock x:Name="TxtVendorIntelTitle" Text="INTEL" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" FontWeight="Bold" FontSize="15"/><TextBlock x:Name="TxtVendorIntelDesc" Text="Lean preset focused on scheduler and low-overhead graphics path." Margin="0,6,0,0" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" FontSize="9" TextWrapping="Wrap"/></StackPanel></RadioButton>
                            </StackPanel>
                        </StackPanel>
                        <Button x:Name="BtnApplyDriver"
                                Grid.Column="1"
                                MinWidth="190"
                                Height="44"
                                Margin="18,0,0,0"
                                VerticalAlignment="Top"
                                Style="{StaticResource PrimaryBtn}"
                                Click="ApplyDriverPreset_Click">
                            <TextBlock x:Name="TxtApplyDriverButton"
                                       Text="APPLY DRIVER PRESET"
                                       FontWeight="Bold"/>
                        </Button>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid x:Name="ProgressOverlay" Background="#CE05050A" Visibility="Collapsed" Opacity="0">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="460">
                <Grid Width="108" Height="108">
                    <Ellipse Stroke="#53387A" StrokeThickness="1.5"/>
                    <Ellipse Width="82" Height="82" Fill="#22192D" Stroke="#8B64E6" StrokeThickness="2"/>
                    <Path Stroke="{StaticResource AccentPrimary}" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M 54,12 A 42,42 0 1 1 53.9,12">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotate" CenterX="54" CenterY="54"/>
                        </Path.RenderTransform>
                    </Path>
                </Grid>
                <TextBlock x:Name="OverlayTitle" Text="Applying tool stack..." Margin="0,26,0,0" Foreground="{StaticResource TextPrimary}" FontFamily="Bahnschrift" FontSize="28" FontWeight="Bold" TextAlignment="Center"/>
                <TextBlock x:Name="OverlayStatus" Text="Restore point first, then selected services and network tools." Margin="0,12,0,0" Foreground="{StaticResource TextSecondary}" FontSize="13" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
