<Page x:Class="ZantesEngine.Pages.GameTunerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      FontFamily="Segoe UI">

    <Page.Resources>
        <Style x:Key="GameCardButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Card"
                                CornerRadius="26"
                                Background="#140F19"
                                BorderBrush="#463365"
                                BorderThickness="1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="BorderBrush" Value="#7A5AB3"/>
                                <Setter TargetName="Card" Property="Background" Value="#171121"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="#120E19"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModeSliderActiveTrack" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Height="14"
                                CornerRadius="999"
                                BorderBrush="#BC9BFF"
                                BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#FFF7FF" Offset="0"/>
                                    <GradientStop Color="#DAB9FF" Offset="0.38"/>
                                    <GradientStop Color="#8B5CF6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14"
                                                  ShadowDepth="0"
                                                  Color="#7F4CFF"
                                                  Opacity="0.34"/>
                            </Border.Effect>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModeSliderInactiveTrack" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Height="14"
                                CornerRadius="999"
                                Background="#15101C"
                                BorderBrush="#312043"
                                BorderThickness="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModeSliderThumb" TargetType="Thumb">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid>
                            <Ellipse Fill="#16FFFFFF"/>
                            <Ellipse Margin="2"
                                     Stroke="#F7EFFF"
                                     StrokeThickness="1.2">
                                <Ellipse.Fill>
                                    <RadialGradientBrush GradientOrigin="0.35,0.35">
                                        <GradientStop Color="#FFFDFE" Offset="0"/>
                                        <GradientStop Color="#DFC4FF" Offset="0.48"/>
                                        <GradientStop Color="#8C5EFF" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="22"
                                                      ShadowDepth="0"
                                                      Color="#A35DFF"
                                                      Opacity="0.62"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <Border Width="12"
                                    Height="12"
                                    CornerRadius="6"
                                    Background="#130C1D"
                                    BorderBrush="#FFF6FF"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GameModeSlider" TargetType="Slider">
            <Setter Property="Foreground" Value="#A778FF"/>
            <Setter Property="Background" Value="#241A34"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Margin="0,4">
                            <Border Height="30"
                                    VerticalAlignment="Center"
                                    CornerRadius="999"
                                    BorderBrush="#4D3771"
                                    BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#16101B" Offset="0"/>
                                        <GradientStop Color="#0D0911" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Border Height="10"
                                    Margin="18,0"
                                    VerticalAlignment="Center"
                                    CornerRadius="999"
                                    Background="#1DFFFFFF"/>
                            <Track x:Name="PART_Track"
                                   Margin="14,0"
                                   VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ModeSliderActiveTrack}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ModeSliderThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ModeSliderInactiveTrack}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                            <UniformGrid Margin="24,0"
                                         Columns="3"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         IsHitTestVisible="False">
                                <Ellipse Width="6"
                                         Height="6"
                                         Fill="#40FFFFFF"
                                         HorizontalAlignment="Left"/>
                                <Ellipse Width="7"
                                         Height="7"
                                         Fill="#78FFFFFF"
                                         HorizontalAlignment="Center"/>
                                <Ellipse Width="6"
                                         Height="6"
                                         Fill="#40FFFFFF"
                                         HorizontalAlignment="Right"/>
                            </UniformGrid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

