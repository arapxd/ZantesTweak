<Page x:Class="ZantesEngine.Pages.GameTunerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      FontFamily="Segoe UI">

    <Page.Resources>
        <Style x:Key="GameCardBtn" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Wrap"
                                Width="266"
                                Height="154"
                                CornerRadius="12"
                                BorderBrush="#44385B"
                                BorderThickness="1"
                                Background="#140F1D"
                                SnapsToDevicePixels="True">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Grid ClipToBounds="True">
                                <ContentPresenter/>
                                <Border x:Name="Glow"
                                        Opacity="0"
                                        CornerRadius="12"
                                        BorderBrush="#8F61FF"
                                        BorderThickness="1"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Wrap" Property="BorderBrush" Value="#4A3A70"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX" To="1.02" Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY" To="1.02" Duration="0:0:0.16"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.16"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Wrap" Property="BorderBrush" Value="#6C2BFF"/>
                                <Setter TargetName="Wrap" Property="Background" Value="#1A1329"/>
                                <Setter TargetName="Glow" Property="Opacity" Value="1"/>
                                <Setter TargetName="Glow" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#8F61FF" BlurRadius="18" ShadowDepth="0" Opacity="0.85"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="22,18,22,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock x:Name="TxtModule" Text="MODULE 02" Foreground="{StaticResource TextSecondary}" FontSize="9" FontWeight="Bold"/>
                <TextBlock x:Name="TxtTitle" Text="GAME TUNER" Foreground="{StaticResource TextPrimary}" FontFamily="Bahnschrift" FontSize="31" FontWeight="Bold"/>
            </StackPanel>

            <Button Grid.Column="1" Content="BACK" Click="GoBack_Click" Style="{StaticResource GhostBtn}"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock x:Name="TxtPresetLabel"
                           Text="POPULAR GAME PRESETS"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="9"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtCardHint"
                           Text="Choose a game card to open preset settings."
                           Foreground="#B4A9D8"
                           FontSize="11"
                           Margin="0,6,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel HorizontalAlignment="Center" Margin="0,2,0,0">
                    <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,16">
                        <RadioButton x:Name="CardValorant"
                                     Tag="valorant"
                                     GroupName="GameCards"
                                     Style="{StaticResource GameCardBtn}"
                                     Checked="GameCard_Checked">
                            <Grid>
                                <Image x:Name="ImgValorant" Source="pack://application:,,,/banner.png" Stretch="UniformToFill" Opacity="0.9"/>
                                <Rectangle Fill="#88090610"/>
                                <StackPanel Margin="12" VerticalAlignment="Bottom">
                                    <TextBlock Text="VALORANT" Foreground="#F7F4FF" FontFamily="Bahnschrift" FontSize="24" FontWeight="Bold"/>
                                    <TextBlock Text="Riot Vanguard tuned competitive preset" Foreground="#BFD0E0" FontSize="10" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </RadioButton>

                        <RadioButton x:Name="CardCs2"
                                     Tag="cs2"
                                     GroupName="GameCards"
                                     Style="{StaticResource GameCardBtn}"
                                     Checked="GameCard_Checked">
                            <Grid>
                                <Image x:Name="ImgCs2" Source="pack://application:,,,/banner.png" Stretch="UniformToFill" Opacity="0.9"/>
                                <Rectangle Fill="#88090711"/>
                                <StackPanel Margin="12" VerticalAlignment="Bottom">
                                    <TextBlock Text="CS2" Foreground="#F7F4FF" FontFamily="Bahnschrift" FontSize="24" FontWeight="Bold"/>
                                    <TextBlock Text="Low-latency input and frame pacing stack" Foreground="#BFD0E0" FontSize="10" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </RadioButton>

                        <RadioButton x:Name="CardHoi4"
                                     Tag="hoi4"
                                     GroupName="GameCards"
                                     Style="{StaticResource GameCardBtn}"
                                     Checked="GameCard_Checked">
                            <Grid>
                                <Image x:Name="ImgHoi4" Source="pack://application:,,,/banner.png" Stretch="UniformToFill" Opacity="0.9"/>
                                <Rectangle Fill="#88070A12"/>
                                <StackPanel Margin="12" VerticalAlignment="Bottom">
                                    <TextBlock Text="HEARTS OF IRON IV" Foreground="#F7F4FF" FontFamily="Bahnschrift" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="Grand strategy CPU stability preset" Foreground="#BFD0E0" FontSize="10" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </RadioButton>

                        <RadioButton x:Name="CardFiveM"
                                     Tag="fivem"
                                     GroupName="GameCards"
                                     Style="{StaticResource GameCardBtn}"
                                     Checked="GameCard_Checked">
                            <Grid>
                                <Image x:Name="ImgFiveM" Source="pack://application:,,,/banner.png" Stretch="UniformToFill" Opacity="0.9"/>
                                <Rectangle Fill="#88050A17"/>
                                <StackPanel Margin="12" VerticalAlignment="Bottom">
                                    <TextBlock Text="FIVEM" Foreground="#F7F4FF" FontFamily="Bahnschrift" FontSize="24" FontWeight="Bold"/>
                                    <TextBlock Text="Roleplay optimized low-latency preset" Foreground="#BFD0E0" FontSize="10" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </RadioButton>

                        <RadioButton x:Name="CardLol"
                                     Tag="lol"
                                     GroupName="GameCards"
                                     Style="{StaticResource GameCardBtn}"
                                     Checked="GameCard_Checked">
                            <Grid>
                                <Image x:Name="ImgLol" Source="pack://application:,,,/banner.png" Stretch="UniformToFill" Opacity="0.9"/>
                                <Rectangle Fill="#88070812"/>
                                <StackPanel Margin="12" VerticalAlignment="Bottom">
                                    <TextBlock Text="LEAGUE" Foreground="#F7F4FF" FontFamily="Bahnschrift" FontSize="24" FontWeight="Bold"/>
                                    <TextBlock Text="Stable ranked profile with clean networking" Foreground="#BFD0E0" FontSize="10" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </RadioButton>

                        <RadioButton x:Name="CardFortnite"
                                     Tag="fortnite"
                                     GroupName="GameCards"
                                     Style="{StaticResource GameCardBtn}"
                                     Checked="GameCard_Checked">
                            <Grid>
                                <Image x:Name="ImgFortnite" Source="pack://application:,,,/banner.png" Stretch="UniformToFill" Opacity="0.9"/>
                                <Rectangle Fill="#88070817"/>
                                <StackPanel Margin="12" VerticalAlignment="Bottom">
                                    <TextBlock Text="FORTNITE" Foreground="#F7F4FF" FontFamily="Bahnschrift" FontSize="24" FontWeight="Bold"/>
                                    <TextBlock Text="Low-latency battle royale profile" Foreground="#BFD0E0" FontSize="10" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </RadioButton>

                        <RadioButton x:Name="CardApex"
                                     Tag="apex"
                                     GroupName="GameCards"
                                     Style="{StaticResource GameCardBtn}"
                                     Checked="GameCard_Checked">
                            <Grid>
                                <Image x:Name="ImgApex" Source="pack://application:,,,/banner.png" Stretch="UniformToFill" Opacity="0.9"/>
                                <Rectangle Fill="#880A0612"/>
                                <StackPanel Margin="12" VerticalAlignment="Bottom">
                                    <TextBlock Text="APEX LEGENDS" Foreground="#F7F4FF" FontFamily="Bahnschrift" FontSize="22" FontWeight="Bold"/>
                                    <TextBlock Text="Frame consistency and net stack focus" Foreground="#BFD0E0" FontSize="10" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </RadioButton>

                        <RadioButton x:Name="CardPubg"
                                     Tag="pubg"
                                     GroupName="GameCards"
                                     Style="{StaticResource GameCardBtn}"
                                     Checked="GameCard_Checked">
                            <Grid>
                                <Image x:Name="ImgPubg" Source="pack://application:,,,/banner.png" Stretch="UniformToFill" Opacity="0.9"/>
                                <Rectangle Fill="#880D0A12"/>
                                <StackPanel Margin="12" VerticalAlignment="Bottom">
                                    <TextBlock Text="PUBG" Foreground="#F7F4FF" FontFamily="Bahnschrift" FontSize="24" FontWeight="Bold"/>
                                    <TextBlock Text="Stable BR preset with background trim" Foreground="#BFD0E0" FontSize="10" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </RadioButton>

                        <RadioButton x:Name="CardR6"
                                     Tag="r6"
                                     GroupName="GameCards"
                                     Style="{StaticResource GameCardBtn}"
                                     Checked="GameCard_Checked">
                            <Grid>
                                <Image x:Name="ImgR6" Source="pack://application:,,,/banner.png" Stretch="UniformToFill" Opacity="0.9"/>
                                <Rectangle Fill="#88070C13"/>
                                <StackPanel Margin="12" VerticalAlignment="Bottom">
                                    <TextBlock Text="RAINBOW SIX" Foreground="#F7F4FF" FontFamily="Bahnschrift" FontSize="22" FontWeight="Bold"/>
                                    <TextBlock Text="Input sharpness + CPU background cut" Foreground="#BFD0E0" FontSize="10" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </RadioButton>

                        <RadioButton x:Name="CardOw2"
                                     Tag="ow2"
                                     GroupName="GameCards"
                                     Style="{StaticResource GameCardBtn}"
                                     Checked="GameCard_Checked">
                            <Grid>
                                <Image x:Name="ImgOw2" Source="pack://application:,,,/banner.png" Stretch="UniformToFill" Opacity="0.9"/>
                                <Rectangle Fill="#88060D15"/>
                                <StackPanel Margin="12" VerticalAlignment="Bottom">
                                    <TextBlock Text="OVERWATCH 2" Foreground="#F7F4FF" FontFamily="Bahnschrift" FontSize="22" FontWeight="Bold"/>
                                    <TextBlock Text="Esports-style latency and frametime tune" Foreground="#BFD0E0" FontSize="10" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </RadioButton>
                    </WrapPanel>

                    <Border x:Name="SelectedGamePanel"
                            Width="980"
                            MaxWidth="980"
                            Background="#0D0914"
                            BorderBrush="#2C2350"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="420"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="#151027"
                                    BorderBrush="#312650"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12">
                                <StackPanel>
                                    <TextBlock x:Name="TxtSelectedGameLabel" Text="SELECTED GAME" Foreground="{StaticResource TextSecondary}" FontSize="9" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtSelectedGameName" Text="VALORANT" Foreground="{StaticResource TextPrimary}" FontFamily="Bahnschrift" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                                    <TextBlock x:Name="TxtSelectedGameHint" Text="Vanguard compatibility included." Foreground="#BFD0E0" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>

                                    <Button x:Name="BtnApplySelectedPreset"
                                            Content="APPLY GAME PRESET"
                                            Click="ApplySelectedPreset_Click"
                                            Style="{StaticResource PrimaryBtn}"
                                            Height="40"
                                            Margin="0,14,0,0"/>

                                    <CheckBox x:Name="CbAutoDetect"
                                              Content="Auto-detect running game EXE"
                                              Style="{StaticResource SoftCheck}"
                                              Margin="0,16,0,0"
                                              IsChecked="True"/>
                                    <TextBlock x:Name="TxtAutoStatus" Text="Waiting for game process..." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,6,0,0" TextWrapping="Wrap"/>

                                    <TextBlock x:Name="TxtApplyStatus" Text="Profile engine ready." Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,12,0,0" TextWrapping="Wrap"/>

                                    <Border Background="#141522"
                                            BorderBrush="#44385B"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="10"
                                            Margin="0,12,0,0">
                                        <StackPanel>
                                            <TextBlock x:Name="TxtUpdateWatchLabel"
                                                       Text="GAME UPDATE WATCHER"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="9"
                                                       FontWeight="Bold"/>
                                            <UniformGrid Columns="2" Margin="0,8,0,0">
                                                <Button x:Name="BtnWatchRegister"
                                                        Content="REGISTER BUILD"
                                                        Click="WatchRegister_Click"
                                                        Style="{StaticResource GhostBtn}"
                                                        Margin="0,0,5,0"/>
                                                <Button x:Name="BtnWatchCheck"
                                                        Content="CHECK UPDATE"
                                                        Click="WatchCheck_Click"
                                                        Style="{StaticResource GhostBtn}"
                                                        Margin="5,0,0,0"/>
                                            </UniformGrid>
                                            <TextBlock x:Name="TxtWatchStatus"
                                                       Text="No tracked build yet."
                                                       Foreground="#9FB1C7"
                                                       FontSize="10"
                                                       Margin="0,8,0,0"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="FiveMToolsPanel"
                                            Background="#141522"
                                            BorderBrush="#44385B"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="10"
                                            Margin="0,12,0,0"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock x:Name="TxtFiveMToolsTitle"
                                                       Text="FIVEM EXTRA TOOLS"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="9"
                                                       FontWeight="Bold"/>
                                            <Button x:Name="BtnFiveMCleanCache"
                                                    Content="CLEAN FIVEM CACHE"
                                                    Click="FiveMCleanCache_Click"
                                                    Style="{StaticResource GhostBtn}"
                                                    Margin="0,8,0,0"/>
                                            <Button x:Name="BtnFiveMCleanLogs"
                                                    Content="CLEAN LOGS &amp; CRASHES"
                                                    Click="FiveMCleanLogs_Click"
                                                    Style="{StaticResource GhostBtn}"
                                                    Margin="0,8,0,0"/>
                                            <Button x:Name="BtnFiveMFullPack"
                                                    Content="APPLY FIVEM FULL PACK"
                                                    Click="FiveMFullPack_Click"
                                                    Style="{StaticResource GhostBtn}"
                                                    Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Background="#0B0C14"
                                    BorderBrush="#352C47"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12">
                                <StackPanel>
                                    <TextBlock x:Name="TxtProfileSection" Text="MATCH PROFILE" Foreground="{StaticResource TextSecondary}" FontSize="9" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtActiveProfile" Text="Competitive" Foreground="{StaticResource TextPrimary}" FontFamily="Bahnschrift" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                                    <ProgressBar x:Name="ProfileScore" Style="{StaticResource PurpleBar}" Value="76" Maximum="100" Margin="0,16,0,0"/>
                                    <TextBlock x:Name="TxtProfileScore" Text="76% balance score" Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,8,0,0"/>
                                    <TextBlock x:Name="TxtProfileSelect" Text="Select a profile" Foreground="{StaticResource TextSecondary}" FontSize="9" FontWeight="Bold" Margin="0,16,0,0"/>
                                    <Button x:Name="BtnCompetitive" Content="COMPETITIVE" Click="Competitive_Click" Style="{StaticResource GhostBtn}" Margin="0,6,0,0"/>
                                    <Button x:Name="BtnBalanced" Content="BALANCED" Click="Balanced_Click" Style="{StaticResource GhostBtn}" Margin="0,6,0,0"/>
                                    <Button x:Name="BtnUltraFps" Content="ULTRA FPS" Click="UltraFps_Click" Style="{StaticResource GhostBtn}" Margin="0,6,0,0"/>
                                    <Button x:Name="BtnApplyProfile" Content="APPLY TUNER" Click="ApplyCurrentProfile_Click" Style="{StaticResource GhostBtn}" Height="36" Margin="0,14,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>

