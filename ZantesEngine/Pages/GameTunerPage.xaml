                                <TextBlock Text="OPEN PROFILE"
                                           Margin="0,12,0,0"
                                           Foreground="{StaticResource AccentPrimary}"
                                           FontSize="11"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button Tag="OW"
                            Margin="12,0,0,12"
                            Style="{StaticResource GameCardButton}"
                            Click="GameCard_Click"
                            CommandParameter="ow2">
                        <Grid>
                            <Image Source="/Assets/Games/ow2.jpg"
                                   Stretch="UniformToFill"
                                   Opacity="0.34"/>
                            <Rectangle Fill="#C0100D16"/>
                            <Rectangle VerticalAlignment="Bottom" Height="96">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#00100D16" Offset="0"/>
                                        <GradientStop Color="#F014101B" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Border Width="42"
                                    Height="42"
                                    CornerRadius="14"
                                    Background="#221A30"
                                    BorderBrush="#7454A9"
                                    BorderThickness="1"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Margin="18,18,0,0">
                                <TextBlock Text="OW"
                                           Foreground="{StaticResource AccentPrimary}"
                                           FontFamily="Bahnschrift"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Bottom" Margin="18,0,18,16">
                                <TextBlock Text="OVERWATCH 2"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontFamily="Bahnschrift"
                                           FontSize="24"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Fast arena preset with clean capture behavior, sharper responsiveness, and competitive scheduling."
                                           Margin="0,10,0,0"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="13"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="OPEN PROFILE"
                                           Margin="0,12,0,0"
                                           Foreground="{StaticResource AccentPrimary}"
                                           FontSize="11"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </Button>
                </WrapPanel>
            </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid x:Name="DetailView"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button x:Name="BtnBackToLibrary"
                    Width="120"
                    Height="42"
                    HorizontalAlignment="Left"
                    Style="{StaticResource GhostBtn}"
                    Click="BtnBackToLibrary_Click"
                    Content="BACK"/>

            <StackPanel Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="720">
                <TextBlock x:Name="SelectedGameBadge"
                           Text="PROFILE"
                           Foreground="{StaticResource AccentPrimary}"
                           FontSize="11"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="SelectedGameTitle"
                           Text="VALORANT"
                           Margin="0,14,0,0"
                           Foreground="{StaticResource TextPrimary}"
                           FontFamily="Bahnschrift"
                           FontSize="44"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="SelectedGameDescription"
                           Margin="0,14,0,0"
                           Text="Per-title tuning page."
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="14"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>

                <Border Margin="0,30,0,0"
                        Padding="24"
                        CornerRadius="28"
                        Background="#130F18"
                        BorderBrush="#463365"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Padding="14,8"
                                    CornerRadius="999"
                                    Background="#16101D"
                                    BorderBrush="#3F2E59"
                                    BorderThickness="1"
                                    HorizontalAlignment="Left">
                                <TextBlock x:Name="ModeLabelLeft"
                                           Text="QUALITY"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontFamily="Bahnschrift"
                                           FontSize="13"
                                           FontWeight="Bold"/>
                            </Border>
                            <Border Grid.Column="1"
                                    Padding="14,8"
                                    Margin="12,0"
                                    CornerRadius="999"
                                    Background="#1A1322"
                                    BorderBrush="#57407D"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center">
                                <TextBlock x:Name="ModeLabelCenter"
                                           Text="BALANCED"
                                           Foreground="{StaticResource AccentPrimary}"
                                           FontFamily="Bahnschrift"
                                           FontSize="13"
                                           FontWeight="Bold"/>
                            </Border>
                            <Border Grid.Column="2"
                                    Padding="14,8"
                                    CornerRadius="999"
                                    Background="#16101D"
                                    BorderBrush="#3F2E59"
                                    BorderThickness="1"
                                    HorizontalAlignment="Right">
                                <TextBlock x:Name="ModeLabelRight"
                                           Text="PERFORMANCE"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontFamily="Bahnschrift"
                                           FontSize="13"
                                           FontWeight="Bold"/>
                            </Border>
                        </Grid>

                        <Slider x:Name="ModeSlider"
                                Grid.Row="1"
                                Minimum="0"
                                Maximum="100"
                                Value="50"
                                Margin="0,18,0,0"
                                Style="{StaticResource GameModeSlider}"
                                ValueChanged="ModeSlider_ValueChanged"/>

                        <Border Grid.Row="2"
                                Margin="0,22,0,0"
                                Padding="18"
                                CornerRadius="20"
                                Background="#0C0A11"
                                BorderBrush="#37264F"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock x:Name="ModeBadge"
                                           Text="BALANCED"
                                           Foreground="{StaticResource AccentPrimary}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="ModeDescription"
                                           Margin="0,10,0,0"
                                           Text="Good default for stable frametime, visuals, and safer tuning."
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="13"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="ModeDetail"
                                           Margin="0,8,0,0"
                                           Text="Keeps a middle ground between quality and raw performance."
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="12"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Button x:Name="BtnApplyMode"
                        Margin="0,28,0,0"
                        Width="260"
                        Height="56"
                        HorizontalAlignment="Center"
                        Style="{StaticResource PrimaryBtn}"
                        Click="BtnApplyMode_Click"
                        Content="APPLY THIS PROFILE"/>

                <TextBlock x:Name="ApplyStatusText"
                           Margin="0,18,0,0"
                           Text="Choose a side, then apply the selected game profile."
                           Foreground="{StaticResource TextMuted}"
                           FontSize="13"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="ProgressOverlay"
              Visibility="Collapsed"
              Opacity="0"
              Background="#D9040406">
            <Border Width="420"
                    Padding="28"
                    CornerRadius="28"
                    Background="#110F16"
                    BorderBrush="#4A3470"
                    BorderThickness="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ProgressBar IsIndeterminate="True"
                                 Style="{StaticResource PurpleBar}"
                                 Height="8"/>

                    <TextBlock x:Name="OverlayStatusText"
                               Grid.Row="1"
                               Margin="0,18,0,0"
                               Text="Applying game profile..."
                               Foreground="{StaticResource TextPrimary}"
                               FontFamily="Bahnschrift"
                               FontSize="26"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
